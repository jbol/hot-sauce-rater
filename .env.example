# ── Hot Sauce Passport — Environment Variables ──────────────────────────────
# Copy this file to .env for local development.
# On Hostinger, set these directly in hPanel → your app → Environment Variables.
# Never commit .env to git.

# ── Required in production ───────────────────────────────────────────────────

# A long random secret used to sign auth tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# ── Optional ─────────────────────────────────────────────────────────────────

# Set automatically by Hostinger — do not set manually on Hostinger.
# Defaults to 3001 in local development.
# PORT=3001

# Override the SQLite database file location.
# Defaults to <project-root>/data/hot-sauce-passport.db
# DB_PATH=/path/to/your/database.db

# Only used in local development (allows the Vite dev server on :5173 to call the API).
# Do not set on Hostinger — same-origin requests don't need CORS.
# CLIENT_ORIGIN=http://localhost:5173
