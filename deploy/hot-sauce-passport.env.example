# EnvironmentFile for the systemd service — copy to /etc/hot-sauce-passport.env
# on the VPS and fill in a real JWT_SECRET. Do NOT commit the real file.
#
#   sudo cp deploy/hot-sauce-passport.env.example /etc/hot-sauce-passport.env
#   # generate a secret and paste it in:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   sudo nano /etc/hot-sauce-passport.env
#   sudo chmod 600 /etc/hot-sauce-passport.env

# Enables static serving of dist/ + the Secure cookie flag. Required.
NODE_ENV=production

# Internal port the Node app listens on (nginx proxies to it). 3001 is fine.
PORT=3001

# REQUIRED: the server refuses to start in production without this.
# A long random hex string — never share or commit it.
JWT_SECRET=replace-me-with-a-long-random-hex-string

# Optional: override where the SQLite database file lives.
# Defaults to <repo>/data/hot-sauce-passport.db, which persists across deploys.
# DB_PATH=/var/lib/hot-sauce-passport/hot-sauce-passport.db
