# Dependencies
node_modules/
.pnpm-store/

# Build output
# NOTE: dist/ is intentionally COMMITTED. Hostinger's build sandbox is mounted
# noexec, so esbuild/vite cannot run there. We build dist/ locally (Node 22 +
# pnpm 11) and commit it; Hostinger only serves it. See DEPLOYING.md.
# dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Package manager — this is a pnpm project.
# Commit pnpm-lock.yaml; never commit other managers' lockfiles.
package-lock.json
yarn.lock

# Environment
.env
.env.local
.env.*.local

# Testing
coverage/

# Database — auto-created at runtime, do not commit (SQLite).
# Anchored to the repo root: src/data/ (the quick-add catalogue) IS committed.
/data/
*.db
*.db-journal
*.db-shm
*.db-wal

# VPS deploy artifacts created on the server (DB backups made by deploy/deploy.sh)
backups/
