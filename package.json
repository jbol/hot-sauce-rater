{
  "name": "hot-sauce-rater",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "preinstall": "npx --yes only-allow pnpm",
    "dev:server": "node --watch --no-warnings server/index.js",
    "dev:client": "vite",
    "dev": "node --no-warnings server/index.js & vite",
    "build": "node scripts/build.mjs",
    "build:vite": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node --no-warnings server/index.js"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^6.4.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
